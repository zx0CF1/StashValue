<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Library</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Version>1.1.1</Version>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PlatformTarget>x64</PlatformTarget>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="ImGui.NET" Version="1.91.6.1" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
  </ItemGroup>

  <Choose>
    <When Condition="'$(Fork)' == 'Gordin'">
      <PropertyGroup>
        <AssemblyName>StashValue-Gordin</AssemblyName>
      </PropertyGroup>
      <ItemGroup>
        <Reference Include="GameHelper">
          <HintPath>..\..\sources\GameHelper-Gordin\GameHelper\bin\Release\net10.0-windows\win-x64\GameHelper.dll</HintPath>
          <Private>false</Private>
        </Reference>
        <Reference Include="GameOffsets">
          <HintPath>..\..\sources\GameHelper-Gordin\GameOffsets\bin\Release\net10.0-windows\win-x64\GameOffsets.dll</HintPath>
          <Private>false</Private>
        </Reference>
      </ItemGroup>
    </When>
    <Otherwise>
      <ItemGroup>
        <ProjectReference Include="..\..\sources\GameHelper-MordWraith\GameHelper\GameHelper.csproj">
          <Private>false</Private>
          <CopyLocalSatelliteAssemblies>false</CopyLocalSatelliteAssemblies>
        </ProjectReference>
      </ItemGroup>
    </Otherwise>
  </Choose>

  <Target Name="CopyFiles" AfterTargets="Build">
    <ItemGroup>
      <_StashValueDeployFiles Include="$(OutDir)$(TargetName)$(TargetExt)" />
    </ItemGroup>
    <Copy SourceFiles="@(_StashValueDeployFiles)"
          DestinationFolder="..\..\sources\GameHelper-MordWraith\GameHelper\$(OutDir)Plugins\$(ProjectName)"
          Condition="'$(Fork)' != 'Gordin'"
          SkipUnchangedFiles="true" />
    <Copy SourceFiles="@(_StashValueDeployFiles)"
          DestinationFolder="..\..\sources\GameHelper-Gordin\GameHelper\$(OutDir)Plugins\$(ProjectName)"
          Condition="'$(Fork)' == 'Gordin' And Exists('..\..\sources\GameHelper-Gordin')"
          SkipUnchangedFiles="true" />
    <Copy SourceFiles="@(_StashValueDeployFiles)"
          DestinationFolder="$(MSBuildProjectDirectory)"
          SkipUnchangedFiles="true" />
  </Target>

  <Target Name="BuildGordinFork" AfterTargets="Build" Condition="'$(Fork)' != 'Gordin'">
    <MSBuild Projects="$(MSBuildProjectFile)" Properties="Fork=Gordin;Configuration=$(Configuration);Platform=$(Platform)" />
  </Target>

</Project>
